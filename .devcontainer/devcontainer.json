{
    "name": "WiiU Development Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "C_Cpp.default.compilerPath": "/opt/devkitpro/devkitPPC/bin/powerpc-eabi-gcc",
                "C_Cpp.default.includePath": [
                    "${workspaceFolder}/**",
                    "/opt/devkitpro/wut/include/**"
                ]
            },
            "extensions": [
                "ms-vscode.cpptools"
            ]
        }
    },
    "remoteUser": "vscode"
}
